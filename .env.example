# Supabase — get these from your Supabase project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Postgres — pooled (transaction mode) for serverless/Drizzle queries
# Found at: Supabase dashboard → Settings → Database → Connection string → Transaction pooler
DATABASE_URL=postgresql://postgres.your-project-id:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require

# Supabase Postgres — session mode (unpooled) for migrations only
# Found at: Supabase dashboard → Settings → Database → Connection string → Session pooler
DATABASE_URL_UNPOOLED=postgresql://postgres:password@db.your-project-id.supabase.co:5432/postgres?sslmode=require

# AI — Groq for simulation analysis (free tier available at console.groq.com)
GROQ_API_KEY=gsk_your-key-here

# AI — Anthropic for hand analyzer
ANTHROPIC_API_KEY=sk-ant-your-key-here

# App URL — used for OAuth redirects
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Rate limiting — Upstash Redis (free tier at upstash.com)
RATELIMIT_REDIS_URL=https://your-instance.upstash.io
RATELIMIT_REDIS_TOKEN=your-token-here

# Error tracking — Sentry (free tier at sentry.io)
SENTRY_DSN=https://your-key@sentry.io/your-project-id
SENTRY_AUTH_TOKEN=your-auth-token-for-sourcemap-upload
